{
  "id": "plain_current_date",
  "description": "A plain date question should use runtime date context and should not require external search.",
  "agent": {
    "name_prefix": "loop-eval-date",
    "preset": "researcher"
  },
  "task": "what is today's date?",
  "expect": {
    "answer_quality": true,
    "contract": "chat",
    "route": "trivial_direct",
    "verdict": "completed",
    "max_turns": 1,
    "max_agent_messages": 1,
    "max_response_words": 20,
    "required_current_date": true,
    "forbidden_response_text": ["I searched", "PACT", "work contract", "execution mode", "scratchpad", "complete_task"]
  },
  "replay_trace": {
    "messages": [
      {
        "author": "operator",
        "content": "what is today's date?"
      },
      {
        "author": "loop-eval-date",
        "content": "Today is May 4, 2026."
      }
    ],
    "audit": [
      {
        "event": "agent_loop_terminal_outcome",
        "kind": "chat",
        "verdict": "completed",
        "route": "trivial_direct",
        "turn": 1
      }
    ],
    "pact_run": {
      "kind": "chat",
      "route": "trivial_direct",
      "verdict": "completed"
    }
  }
}
